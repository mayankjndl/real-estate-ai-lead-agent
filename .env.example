# Gemini AI
GEMINI_API_KEY=

# Internal auth key for admin endpoints
API_AUTH_KEY=

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/realestate_db

# Redis connection string
REDIS_URL=redis://localhost:6379/0

# Twilio credentials
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=whatsapp:+14155238886

# Security & Encryption Keys
JWT_SECRET_KEY=
ADMIN_API_KEY=
STRIPE_WEBHOOK_SECRET=

# Per-client API keys (provisioned by seed.py)
CLIENT_KEY_A=
CLIENT_KEY_B=

# ngrok — get your auth token from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# Set to true on Render/production
IS_PRODUCTION=false

# Set to true for test mode
FOLLOW_UP_TEST_MODE=false

# Set to true for test mode for DLQ
FOLLOW_UP_DLQ_TEST=false

# Set to true for twilio bypass for automation script
TEST_MODE=false

# --- Notification & Escalation Variables ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Sender Account Credentials (Email A)
SMTP_USER=
SMTP_PASS=

# Default Fallback Recipient (Email B - No 2FA required to receive)
ADMIN_EMAIL=

# Twilio Status Callback Tracking
# (Use your ngrok URL for local testing, e.g., https://1234-abcd-efgh.ngrok-free.dev)
WEBHOOK_BASE_URL=